rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Public Data (Read-only for all users) ───────────────────
    // Foods: Anyone can read, only admin or server can write
    match /foods/{foodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories: Anyone can read, only admin can write
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Restaurants: Anyone can read, only admin can write
    match /restaurants/{resId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Orders (Controlled) ────────────────────────────────────
    // Users can read their own orders and create new ones.
    // When using Blaze plan with Cloud Functions, tighten create/update to `false`.
    match /orders/{orderId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      // Allow user to cancel their own order (only if current status is "placed")
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.userId
                    && resource.data.status == "placed"
                    && request.resource.data.status == "cancelled";
      allow delete: if false; // Orders are never deleted
    }

    // ─── User Profiles ───────────────────────────────────────────
    match /users/{userId} {
      // Users can read and update their own profile
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      // Favorites subcollection — only owner can manage
      match /favorites/{favId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Admin Collection ────────────────────────────────────────
    // Only readable by authenticated users (for role checks), never writable from client
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false; // Managed via Firebase Console only
    }
  }
}
